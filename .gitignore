# Private NDA overlay — the separate private repo cloned here (organized by tool:
# zsh/, git/, ssh/, …). Never tracked in the public dotfiles. The zsh loader sources
# dotfiles-private/zsh/*.sh; other tools reference their subdir via include hooks.
.config/dotfiles-private/
.config/zsh/.antidote/
.config/zsh/.zsh_plugins.zsh
.config/zsh/.zcompdump*
.local/share/nvim/
.local/state/nvim/
.cache/nvim/
